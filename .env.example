# Copy this file to .env and fill in your real values. Do not commit .env.
# Required for: docker-compose up

# SQL Server password (must be strong: uppercase + lowercase + digits + symbols, min 8 chars)
SA_PASSWORD=YourStrongSaPassword123!

# JWT secret key (min 32 characters, random string)
ApiSettings__JwtOptions__SecretKey=your-jwt-secret-key-min-32-chars-here

# Gmail SMTP (for sending order/auth emails)
GmailSettings__Email=your-app@gmail.com
GmailSettings__Password=your-gmail-app-password

# CORS: semicolon-separated list of allowed browser origins.
# Local laptop:  http://localhost:30305;http://frontend:30305
# Ubuntu server: http://100.113.13.24:30305;http://frontend:30305
Cors__Origins=http://localhost:30305;http://frontend:30305

# Superadmin seed password (optional – if omitted, uses the default set in docker-compose)
# SEED_SUPERADMIN_PASSWORD=lkjflajljlka@32lkjA32
