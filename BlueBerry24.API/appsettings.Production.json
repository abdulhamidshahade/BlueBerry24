{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "AllowedHosts": "*",
  "Security": {
    "UseForwardedHeaders": true,
    "RequireHttpsRedirection": false,
    "UseHsts": false
  },
  "Database": {
    "RunMigrationsOnStartup": true
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "ApiSettings": {
    "JwtOptions": {
      "RequireHttps": false
    }
  }
}
